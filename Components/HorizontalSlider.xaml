<UserControl x:Class="WindowsAppCoreLib.Components.HorizontalSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:c="clr-namespace:WindowsAppCoreLib"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsAppCoreLib.Components"
             xmlns:cv="clr-namespace:WindowsAppCoreLib.Converter"
             xmlns:dt="clr-namespace:WindowsAppCoreLib.DataTransfer"
             mc:Ignorable="d">
    <UserControl.Resources>
        <cv:NumSum x:Key="Sum" />
        <cv:BoolToHiddenVisibility x:Key="B2H" />
        <cv:StringFormat x:Key="PointToPerc" />

        <local:SliderHandleXLocationConverter x:Key="HandleX" />

        <RadialGradientBrush x:Key="HandleDonut">
            <GradientStop Color="#000000" Offset="1"/>
            <GradientStop Color="#000000" Offset="0.9"/>
            <GradientStop Color="#cbcbcb" Offset="0.89"/>
            <GradientStop Color="#cbcbcb" Offset="0.7"/>
            <GradientStop Color="#000000" Offset="0.69"/>
            <GradientStop Color="#000000" Offset="0.59"/>
            <GradientStop Color="Transparent" Offset="0.58"/>
            <GradientStop Color="Transparent" Offset="0"/>
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="HandleDonutHover">
            <GradientStop Color="#000000" Offset="1"/>
            <GradientStop Color="#000000" Offset="0.9"/>
            <GradientStop Color="#cbcbcb" Offset="0.89"/>
            <GradientStop Color="#cbcbcb" Offset="0.65"/>
            <GradientStop Color="#000000" Offset="0.64"/>
            <GradientStop Color="#000000" Offset="0.54"/>
            <GradientStop Color="Transparent" Offset="0.53"/>
            <GradientStop Color="Transparent" Offset="0"/>
        </RadialGradientBrush>

        <Style x:Key="Handle" TargetType="Border">
            <Setter Property="Height" Value="24" />
            <Setter Property="Width" Value="24" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Background" Value="{StaticResource HandleDonut}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HandleDonutHover}" />
                </Trigger>
                <Trigger Property="IsMouseCaptured" Value="True">
                    <!--<Setter Property="Cursor" Value="None" />-->
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Canvas>
        <Border
            Height="12"
            Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}, Path=BarWidth}"
            Background="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}, Path=BarBrush}"
            CornerRadius="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}, Path=BarCornerRadius}"
            Cursor="Hand"
            Panel.ZIndex="0" />
        <Border
            x:Name="Handle"
            Style="{StaticResource Handle}"
            c:Mouse.DragCommand="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}, Path=DragCommand}"            
            Canvas.Top="-6"
            Panel.ZIndex="1">
            <Canvas.Left>
                <MultiBinding 
                    Converter="{StaticResource HandleX}" 
                    ConverterParameter="0">
                    <Binding 
                        RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}"
                        Path="Value"/>
                    <Binding 
                        RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}"
                        Path="MinValue"/>
                    <Binding 
                        RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}"
                        Path="MaxValue"/>
                    <Binding 
                        RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}"
                        Path="BarWidth"/>
                </MultiBinding>
            </Canvas.Left>
        </Border>
        <local:Tooltip
            TextContent="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}, Path=Value, Converter={StaticResource PointToPerc}, ConverterParameter='([0-9]?,) %'}"
            Visibility="Visible"
            FontFamily="Consolas"
            BorderBackground="Gray"
            Canvas.Top="{Binding ElementName=Handle, Path=(Canvas.Top), Converter={StaticResource Sum}, ConverterParameter=-20}"
            Canvas.Left="{Binding ElementName=Handle, Path=(Canvas.Left), Converter={StaticResource Sum}, ConverterParameter=20}"
            Panel.ZIndex="2">
            <!--<Canvas.Left>
                <MultiBinding 
                    Converter="{StaticResource HandleX}"
                    ConverterParameter="20">
                    <Binding 
                        RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}"
                        Path="Value"/>
                    <Binding 
                        RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}"
                        Path="MinValue"/>
                    <Binding 
                        RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}"
                        Path="MaxValue"/>
                    <Binding 
                        RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type local:HorizontalSlider}}"
                        Path="BarWidth"/>
                </MultiBinding>
            </Canvas.Left>-->
        </local:Tooltip>
    </Canvas>
</UserControl>
