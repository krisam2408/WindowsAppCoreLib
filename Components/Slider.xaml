<UserControl x:Class="WindowsAppCoreLib.Components.Slider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:c="clr-namespace:WindowsAppCoreLib"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsAppCoreLib.Components"
             xmlns:cv="clr-namespace:WindowsAppCoreLib.Converter"
             mc:Ignorable="d">
    <UserControl.Resources>
        <cv:NumSum x:Key="Sum" />
        <cv:BoolToHiddenVisibility x:Key="B2H" />
        <cv:StringFormat x:Key="PointToPerc" />

        <RadialGradientBrush x:Key="HandleDonut">
            <GradientStop Color="#000000" Offset="1"/>
            <GradientStop Color="#000000" Offset="0.9"/>
            <GradientStop Color="#cbcbcb" Offset="0.89"/>
            <GradientStop Color="#cbcbcb" Offset="0.7"/>
            <GradientStop Color="#000000" Offset="0.69"/>
            <GradientStop Color="#000000" Offset="0.59"/>
            <GradientStop Color="Transparent" Offset="0.58"/>
            <GradientStop Color="Transparent" Offset="0"/>
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="HandleDonutHover">
            <GradientStop Color="#000000" Offset="1"/>
            <GradientStop Color="#000000" Offset="0.9"/>
            <GradientStop Color="#cbcbcb" Offset="0.89"/>
            <GradientStop Color="#cbcbcb" Offset="0.65"/>
            <GradientStop Color="#000000" Offset="0.64"/>
            <GradientStop Color="#000000" Offset="0.54"/>
            <GradientStop Color="Transparent" Offset="0.53"/>
            <GradientStop Color="Transparent" Offset="0"/>
        </RadialGradientBrush>

        <Style x:Key="Handle" TargetType="Border">
            <Setter Property="Height" Value="24" />
            <Setter Property="Width" Value="24" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Background" Value="{StaticResource HandleDonut}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HandleDonutHover}" />
                </Trigger>
                <Trigger Property="IsMouseCaptured" Value="True">
                    <Setter Property="Cursor" Value="None" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Canvas>
        <Border
            Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:Slider}}, Path=BarHeight}"
            Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:Slider}}, Path=BarWidth}"
            Background="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:Slider}}, Path=BarBrush}"
            CornerRadius="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:Slider}}, Path=BarCornerRadius}"
            Cursor="Hand"
            Panel.ZIndex="0" />
        <Border
            Style="{StaticResource Handle}"
            Canvas.Top="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:Slider}}, Path=HandlePosition.Y}"
            Canvas.Left="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:Slider}}, Path=HandlePosition.X}"
            c:Mouse.DragCommand="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:Slider}}, Path=DragCommand}"            
            Panel.ZIndex="1" />
        <local:Tooltip
            TextContent="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:Slider}}, Path=Value, Converter={StaticResource PointToPerc}, ConverterParameter='([0-9]?,) %'}"
            Canvas.Top="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:Slider}}, Path=HandlePosition.Y, Converter={StaticResource Sum}, ConverterParameter=-20}"
            Canvas.Left="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:Slider}}, Path=HandlePosition.X, Converter={StaticResource Sum}, ConverterParameter=20}"
            Visibility="Visible"
            FontFamily="Consolas"
            BorderBackground="Gray"
            Panel.ZIndex="2"/>
    </Canvas>
</UserControl>
