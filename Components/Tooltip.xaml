<UserControl x:Class="WindowsAppCoreLib.Components.Tooltip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsAppCoreLib.Components"
             mc:Ignorable="d">
    <Border
        Height="17"
        CornerRadius="4"
        Padding="4,2"
        Background="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:Tooltip}}, Path=BorderBackground}">
        <TextBox 
            Background="Transparent"
            BorderThickness="0"
            FontSize="11"
            Foreground="#cccccc"
            Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:Tooltip}}, Path=TextContent}" />
    </Border>
</UserControl>
