<UserControl x:Class="WindowsAppCoreLib.Components.HSLColorWheelPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsAppCoreLib.Components"
             xmlns:c="clr-namespace:WindowsAppCoreLib"
             xmlns:cv="clr-namespace:WindowsAppCoreLib.Converter"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             Width="256"
             Height="380"
             Background="#15ffffff">
    <UserControl.Resources>
        <sys:String x:Key="AlphaBase64">
            
        </sys:String>

        <sys:String x:Key="GradientBase64">
            
        </sys:String>
        
        <cv:Base64ToImage x:Key="B64" />
        <cv:NullValue x:Key="Null" />
        <cv:PointX x:Key="XPoint" />
        
        <LinearGradientBrush x:Key="B2W"
            StartPoint="0,0.5"
            EndPoint="1,0.5">
            <GradientStop Color="#ffffffff" Offset="0" />
            <GradientStop Color="#7fffffff" Offset="0.5" />
            <GradientStop Color="#ff000000" Offset="1" />
        </LinearGradientBrush>

        <ImageBrush x:Key="HSLWheelBrush"
            ImageSource="{Binding Source={StaticResource GradientBase64}, Converter={StaticResource B64}}" />

        <ImageBrush x:Key="AlphaPattern"
            TileMode="Tile"
            Viewport="0,0,0.1,2"
            ViewportUnits="RelativeToBoundingBox"
            ImageSource="{Binding Source={StaticResource AlphaBase64}, Converter={StaticResource B64}}"/>
        <VisualBrush x:Key="AlphaSliderBarBrush">
            <VisualBrush.Visual>
                <Canvas
                    Width="232"
                    Height="12">
                    <Rectangle 
                        Width="232"
                        Height="12"
                        Fill="{StaticResource AlphaPattern}"
                        Panel.ZIndex="0" />
                    <Rectangle 
                        Width="232"
                        Height="13"
                        Canvas.Top="-0.5"
                        Fill="{StaticResource B2W}"
                        Panel.ZIndex="1" />
                </Canvas>
            </VisualBrush.Visual>
        </VisualBrush>
    </UserControl.Resources>
    <Canvas>

        <!-- Hue -->
        <Border
            Width="256"
            Height="256"
            Background="Transparent"
            BorderThickness="2"
            BorderBrush="White">
            <Border
                    Width="8"
                    Height="8"
                    CornerRadius="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="White"/>

        </Border>

        <!--<local:HorizontalSlider
            BarWidth="256"
            BarHeight="256"
            BarBrush="{StaticResource HSLWheelBrush}" />-->

        <!-- Alpha -->
        <local:HorizontalSlider
            BarHeight="12"
            BarWidth="232"
            BarCornerRadius="6"
            BarBrush="{StaticResource AlphaSliderBarBrush}"
            Decimals="1"
            MinValue="0"
            MaxValue="100"
            Value="50"
            Canvas.Top="290"
            Canvas.Left="12"
            />
    </Canvas>
</UserControl>
