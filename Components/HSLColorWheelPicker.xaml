<UserControl x:Class="WindowsAppCoreLib.Components.HSLColorWheelPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsAppCoreLib.Components"
             xmlns:c="clr-namespace:WindowsAppCoreLib"
             xmlns:cv="clr-namespace:WindowsAppCoreLib.Converter"
             xmlns:dt="clr-namespace:WindowsAppCoreLib.DataTransfer"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             Width="256"
             Height="380"
             Background="#15ffffff">
    <UserControl.Resources>
        <sys:Double x:Key="Radius">110</sys:Double>
        <sys:Double x:Key="Size">64</sys:Double>
        <sys:Double x:Key="AlphaMin">0</sys:Double>
        <sys:Double x:Key="AlphaMax">100</sys:Double>
        
        <sys:String x:Key="AlphaBase64">
            
        </sys:String>
        
        <cv:Base64ToImage x:Key="B64" />
        <cv:NullValue x:Key="Null" />
        <cv:DefaultValue x:Key="Def" />
        <cv:NumFactor x:Key="Factor" />
        <cv:PointX x:Key="XPoint" />
        
        <RadialGradientBrush x:Key="HueDonutOpacityMask">
            <GradientStop Color="Transparent" Offset="0.95"/>
            <GradientStop Color="White" Offset="0.949"/>
            <GradientStop Color="White" Offset="0.801"/>
            <GradientStop Color="Transparent" Offset="0.8"/>
        </RadialGradientBrush>
        <LinearGradientBrush x:Key="B2W"
            StartPoint="0,0.5"
            EndPoint="1,0.5">
            <GradientStop Color="#ffffffff" Offset="0" />
            <GradientStop Color="#7fffffff" Offset="0.5" />
            <GradientStop Color="#ff000000" Offset="1" />
        </LinearGradientBrush>
        <RadialGradientBrush x:Key="HandleDonut">
            <GradientStop Color="#000000" Offset="1"/>
            <GradientStop Color="#000000" Offset="0.9"/>
            <GradientStop Color="#cbcbcb" Offset="0.89"/>
            <GradientStop Color="#cbcbcb" Offset="0.7"/>
            <GradientStop Color="#000000" Offset="0.69"/>
            <GradientStop Color="#000000" Offset="0.59"/>
            <GradientStop Color="Transparent" Offset="0.58"/>
            <GradientStop Color="Transparent" Offset="0"/>
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="HandleDonutHover">
            <GradientStop Color="#000000" Offset="1"/>
            <GradientStop Color="#000000" Offset="0.9"/>
            <GradientStop Color="#cbcbcb" Offset="0.89"/>
            <GradientStop Color="#cbcbcb" Offset="0.65"/>
            <GradientStop Color="#000000" Offset="0.64"/>
            <GradientStop Color="#000000" Offset="0.54"/>
            <GradientStop Color="Transparent" Offset="0.53"/>
            <GradientStop Color="Transparent" Offset="0"/>
        </RadialGradientBrush>
        <ImageBrush x:Key="AlphaPattern"
            TileMode="Tile"
            Viewport="0,0,0.1,2"
            ViewportUnits="RelativeToBoundingBox"
            ImageSource="{Binding Source={StaticResource AlphaBase64}, Converter={StaticResource B64}}"/>
        <VisualBrush x:Key="SliderBarBrush">
            <VisualBrush.Visual>
                <Canvas
                    Width="232"
                    Height="12">
                    <Rectangle 
                        Width="232"
                        Height="12"
                        Fill="{StaticResource AlphaPattern}"
                        Panel.ZIndex="0" />
                    <Rectangle 
                        Width="232"
                        Height="13"
                        Canvas.Top="-0.5"
                        Fill="{StaticResource B2W}"
                        Panel.ZIndex="1" />
                </Canvas>
            </VisualBrush.Visual>
        </VisualBrush>
        
        <x:Array x:Key="HueStops" Type="dt:CrossRadialStop">
            <dt:CrossRadialStop 
                Degrees="0"
                Radius="{StaticResource Radius}"
                Start="#ff0000"
                Main="#ff0000"
                End="#ff8200" />
            <dt:CrossRadialStop 
                Degrees="30"
                Radius="{StaticResource Radius}"
                Start="#ff8200"
                Main="#ff8200"
                End="#ffff00" />
            <dt:CrossRadialStop 
                Degrees="60"
                Radius="{StaticResource Radius}"
                Start="#ffff00"
                Main="#ffff00"
                End="#ffff00" />
            <dt:CrossRadialStop 
                Degrees="90"
                Radius="{StaticResource Radius}"
                Start="#7fff00"
                Main="#7fff00"
                End="#7fff00" />
            <dt:CrossRadialStop 
                Degrees="120"
                Radius="{StaticResource Radius}"
                Start="#00ff00"
                Main="#00ff00"
                End="#00ff00" />
            <dt:CrossRadialStop 
                Degrees="150"
                Radius="{StaticResource Radius}"
                Start="#00ff7f"
                Main="#00ff7f"
                End="#00ff7f" />
            <dt:CrossRadialStop 
                Degrees="180"
                Radius="{StaticResource Radius}"
                Start="#00ffff"
                Main="#00ffff"
                End="#00ffff" />
            <dt:CrossRadialStop 
                Degrees="210"
                Radius="{StaticResource Radius}"
                Start="#0080ff"
                Main="#0080ff"
                End="#0080ff" />
            <dt:CrossRadialStop 
                Degrees="240"
                Radius="{StaticResource Radius}"
                Start="#0000ff"
                Main="#0000ff"
                End="#0000ff" />
            <dt:CrossRadialStop 
                Degrees="270"
                Radius="{StaticResource Radius}"
                Start="#8000ff"
                Main="#8000ff"
                End="#8000ff" />
            <dt:CrossRadialStop 
                Degrees="300"
                Radius="{StaticResource Radius}"
                Start="#ff00ff"
                Main="#ff00ff"
                End="#ff00ff" />
            <dt:CrossRadialStop 
                Degrees="330"
                Radius="{StaticResource Radius}"
                Start="#ff007f"
                Main="#ff007f"
                End="#ff007f" />
        </x:Array>
        
        <Style x:Key="Handle" TargetType="Border">
            <Setter Property="Height" Value="24" />
            <Setter Property="Width" Value="24" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Background" Value="{StaticResource HandleDonut}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HandleDonutHover}" />
                </Trigger>
                <Trigger Property="IsMouseCaptured" Value="True">
                    <Setter Property="Cursor" Value="None" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Canvas>

        <!-- Hue -->
        <Border
            Width="256"
            Height="256"
            Background="Transparent"
            BorderThickness="2"
            BorderBrush="White">
            <Border
                    Width="8"
                    Height="8"
                    CornerRadius="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="White"/>

        </Border>
        
        <ItemsControl
            ItemsSource="{StaticResource HueStops}"
            OpacityMask="{StaticResource HueDonutOpacityMask}"
            Background="#20ffffff"
            Width="256"
            Height="256">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="dt:CrossRadialStop">
                    <Canvas>
                        <Border
                            Width="{StaticResource Size}"
                            Height="{Binding Source={StaticResource Size}, Converter={StaticResource Factor}, ConverterParameter=0.5}">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <TranslateTransform 
                                        X="{Binding Source={StaticResource Size}, Converter={StaticResource Factor}, ConverterParameter=-0.5}" 
                                        Y="{Binding Source={StaticResource Size}, Converter={StaticResource Factor}, ConverterParameter=-0.25}" />
                                    <RotateTransform Angle="{Binding Degrees, Converter={StaticResource Def}, ConverterParameter=0.0}" />
                                    <TranslateTransform X="128" Y="128" />
                                    <TranslateTransform 
                                        X="{Binding Position.X}" 
                                        Y="{Binding Position.Y, Converter={StaticResource Factor}, ConverterParameter=-1.0}" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="{Binding Start, Converter={StaticResource Null}}" Offset="0" />
                                    <GradientStop Color="{Binding Main, Converter={StaticResource Null}}" Offset="0.5" />
                                    <GradientStop Color="{Binding End, Converter={StaticResource Null}}" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Canvas>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        
        <!-- Alpha -->
        <local:Slider
            BarHeight="12"
            BarWidth="232"
            BarCornerRadius="6"
            BarBrush="{StaticResource SliderBarBrush}"
            Decimals="1"
            MinValue="0,0"
            MaxValue="100,0"
            Value="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:HSLColorWheelPicker}}, Path=Alpha, Converter={StaticResource XPoint}, ConverterParameter=0, Mode=TwoWay}"
            Canvas.Top="290"
            Canvas.Left="12"
            />
    </Canvas>
</UserControl>
